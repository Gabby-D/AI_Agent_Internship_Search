AI_PROVIDER_API_KEY=
AI_PROVIDER=auto
AI_PROVIDER_MODEL=gemini-2.5-flash
# Set to true only when you want Gemini scoring prompts to include private/resume_summary.md.
# Resume text is never sent by default. Keep resume summaries short and review what you store locally.
AI_RESUME_SCORING_ENABLED=false
EMAIL_FROM=
EMAIL_TO=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=true
TAVILY_API_KEY=
# Optional Google Custom Search fallback for internet-search and job-board search.
# Create a Programmable Search Engine at https://programmablesearchengine.google.com/
# Enable "Search the entire web", then add the API key and search engine ID below.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CSE_ID=
INTERNET_SEARCH_PROVIDER=auto
